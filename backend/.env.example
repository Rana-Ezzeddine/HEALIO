# Database Configuration
DB_NAME=healio_dev
TEST_DB_NAME=healio_test
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_key_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m

# Server Configuration
PORT=5050
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5173

# Email Verification
APP_BASE_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="HEALIO <no-reply@healio.local>"
EMAIL_VERIFICATION_TTL_MS=86400000
PASSWORD_RESET_TTL_MS=3600000

DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/healio_dev?schema=public"

# Social Auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5050/api/auth/google/callback

# Doctor Review Access
DOCTOR_REVIEWER_EMAILS=doctor@doctor.com,reviewer2@example.com
DOCTOR_REVIEWER_IDS=
DOCTOR_REVIEWER_API_KEY=
