{
  "name": "healio-backend",
  "version": "1.0.0",
  "description": "HEALIO Healthcare Management Platform - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "node setup-db.js",
    "db:optimize": "node src/scripts/optimize-database.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate",
    "test:integration": "NODE_ENV=test node --test tests/integration/**/*.test.js",
    "test:e2e": "NODE_ENV=test node --test tests/e2e/**/*.test.js",
    "test:sprint3": "npm run test:integration && npm run test:e2e"
  },
  "keywords": [
    "healthcare",
    "medical",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.1.1"
  }
}
